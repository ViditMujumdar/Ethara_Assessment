{
  "name": "ethara-assessment",
  "private": true,
  "version": "1.0.0",
  "description": "TaskFlow Manager — frontend + backend",
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c cyan,magenta \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix backend",
    "build": "npm run build --prefix frontend",
    "start": "node src/server.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.x"
  },
  "type": "module",
  "dependencies": {
    "bcryptjs": "2.4.3",
    "bullmq": "5.34.5",
    "cloudinary": "2.5.1",
    "compression": "1.7.5",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.9.3",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "nodemailer": "6.9.16",
    "openai": "4.77.0",
    "razorpay": "2.9.5",
    "socket.io": "^4.8.3",
    "stripe": "17.5.0",
    "uuid": "11.0.3",
    "winston": "3.17.0",
    "zod": "3.24.1"
  }
}
